actionHandlers.remindAdd = async ({ message, keyword, rest }) => {
  const token = (rest || '').split(/\s+/)[0] || '';
  const target = await resolveUserTarget(message, token);
  if (!target) return sendReply(message, getResponse('noId'));
  const enabled = new Set(remindPrefs.enabled || []);
  if (enabled.has(target.id)) {
    await sendReply(message, getResponse('remindAddExists', { target: target.mention }));
    return;
  }
  enabled.add(target.id);
  saveRemindPrefs({ enabled: [...enabled] });
  await sendReply(message, getResponse('remindAddAdded', { target: target.mention }));
  logCommandRun(message, 'remindadd', keyword);
};

