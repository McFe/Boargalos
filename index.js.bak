actionHandlers.editMessage = async ({ message, rest, keyword }) => {
  const targetMsg = await fetchRepliedMessage(message);
  const newBody = rest.trim();
  if (!targetMsg) {
    await sendReply(message, getResponse('editNoReply'));
    logCommandRun(message, 'edit', keyword);
    return;
  }
  if (!newBody) {
    await sendReply(message, getResponse('editUsage'));
    logCommandRun(message, 'edit', keyword);
    return;
  }
  try {
    await targetMsg.edit(newBody);
  } catch (err) {
    console.warn('edit failed:', err?.message || err);
    await sendReply(message, getResponse('editFail'));
  }
  logCommandRun(message, 'edit', keyword);
};

