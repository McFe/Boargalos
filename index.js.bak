const slashNameToId = new Map();
const sanitizeSlashName = (value, fallback) => {
  let name = String(value || '')
    .trim()
    .replace(/^[^\w]+/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9_-]/g, '');
  if (!name && fallback) {
    name = String(fallback)
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9_-]/g, '');
  }
  if (!name) name = 'cmd';
  return name.slice(0, 32) || 'cmd';
};
const slashCommandData = (() => {
  const names = new Set();
  const data = [];
  for (const id of commandIds) {
    const def = commandDef(id);
    const name = sanitizeSlashName(triggerFor(id), id);
    if (!name || names.has(name)) continue;
    names.add(name);
    slashNameToId.set(name, id);
    data.push({
      name,
      description: `Run ${commandLabel(id)}`,
      options: [
