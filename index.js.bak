const registerSlashCommandsForGuild = async (guild) => {
  if (!guild?.commands?.set) return;
  if (!slashCommandData.length) return;
  try {
    await guild.commands.set(slashCommandData);
    console.log(`[slash] registered ${slashCommandData.length} commands in guild ${guild.id}`);
  } catch (err) {
    console.warn(`failed to register slash commands for guild ${guild.id}:`, err?.message || err);
  }
};

const registerSlashCommands = async () => {
  if (!client.application) return;
  if (!slashCommandData.length) {
    console.warn('no slash commands to register');
    return;
  }
  try {
    await client.application.commands.set(slashCommandData);
    console.log(`[slash] registered ${slashCommandData.length} global commands`);
  } catch (err) {
    console.warn('failed to register global slash commands:', err?.message || err);
  }
  const guilds = Array.from(client.guilds.cache.values());
  await Promise.all(guilds.map((g) => registerSlashCommandsForGuild(g)));
};

